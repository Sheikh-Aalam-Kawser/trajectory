rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Default-Deny Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Users Collection Rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. Commitments Collection Rules (Root Level)
    match /commitments/{commitmentId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // 4. Adaptations Collection Rules (Root Level)
    match /adaptations/{adaptationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Adaptations are historical and immutable
    }

    // 5. Reflections Collection Rules (Root Level)
    match /reflections/{reflectionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Reflections are historical and immutable
    }
  }
}
